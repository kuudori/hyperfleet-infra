# Base values for HyperFleet API

image:
  registry: {{ env "REGISTRY" | default "quay.io" }}
  repository: {{ env "API_REPOSITORY" | default "redhat-services-prod/hyperfleet-tenant/hyperfleet/hyperfleet-api" }}
  tag: {{ env "API_IMAGE_TAG" | default "dev" }}
  pullPolicy: {{ env "IMAGE_PULL_POLICY" | default "IfNotPresent" }}

service:
  type: {{ .Values.serviceType }}

config:
  adapters:
    required:
      cluster:
        {{- range .Values.adapters }}
        {{- if eq .resourceType "clusters" }}
        - {{ .name }}
        {{- end }}
        {{- end }}
      nodepool:
        {{- range .Values.adapters }}
        {{- if eq .resourceType "nodepools" }}
        - {{ .name }}
        {{- end }}
        {{- end }}
  {{ if eq (env "JWT_AUTH_ENABLED" | default "false") "true" }}
  server:
    jwt:
      enabled: true
      configs:
        - issuer_url: {{ env "OIDC_ISSUER_URL" }}
          jwk_cert_url: {{ env "OIDC_JWKS_URL" }}
          audience: hyperfleet-api
          identity_claim: sub
        - issuer_url: https://accounts.google.com
          jwk_cert_url: https://www.googleapis.com/oauth2/v3/certs
          identity_claim: email
  {{ end }}